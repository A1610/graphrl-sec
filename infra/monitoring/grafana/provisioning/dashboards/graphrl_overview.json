{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "GraphRL-Sec system overview — API, detection pipeline, and infrastructure",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "API Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "up{job=\"graphrl-api\"}",
          "legendFormat": "API"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "API Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(http_requests_total{job=\"graphrl-api\"}[1m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 1 },
      "id": 4,
      "title": "API Latency (p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"graphrl-api\"}[5m]))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "title": "Detection Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 6,
      "title": "Alerts per Minute",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(graphrl_alerts_total[1m]) * 60",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 7,
      "title": "Anomaly Score Distribution",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(graphrl_anomaly_score_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(graphrl_anomaly_score_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["graphrl-sec", "overview"],
  "title": "GraphRL-Sec Overview",
  "uid": "graphrl-overview-v1",
  "version": 1
}
