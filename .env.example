# ============================================================
# GraphRL-Sec — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphrl_sec
POSTGRES_USER=graphrl
POSTGRES_PASSWORD=graphrlsec123

# ----------------------------------------------------------
# Neo4j
# ----------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrlsec123

# ----------------------------------------------------------
# Kafka / Redpanda
# ----------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=graphrlsec123
REDIS_URL=redis://:graphrlsec123@localhost:6379/0

# ----------------------------------------------------------
# FastAPI Backend
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------------------------------------
# ML / GPU
# ----------------------------------------------------------
# Options: cuda, cpu
DEVICE=cuda
VRAM_LIMIT_GB=6
MIXED_PRECISION=true
# Gradient checkpointing for large models
GRADIENT_CHECKPOINTING=true
# Mini-batch size for graph sampling
GRAPH_BATCH_SIZE=512

# ----------------------------------------------------------
# Monitoring
# ----------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------------------------------------------------
# Data paths (relative to project root)
# ----------------------------------------------------------
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_GRAPHS_DIR=data/graphs
MODELS_DIR=models
